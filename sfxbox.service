[Unit]
Description=SFX Box keyboard-driven sound effects service
After=sound.target local-fs.target
Wants=sound.target

[Service]
Type=simple
User=bbplayers
Group=bbplayers
WorkingDirectory=/home/bbplayers/sfxbox
ExecStart=/usr/bin/python3 /home/bbplayers/sfxbox/main.py
Restart=on-failure
RestartSec=2

# Send stdout/stderr to the journal
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target